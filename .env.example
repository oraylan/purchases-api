# ============================================================================
# purchases-api — variáveis de ambiente
# ============================================================================
#
# Copie esse arquivo pra .env e preencha. O .env NÃO é versionado.
# Em boot, src/config/env.js valida que todas as obrigatórias estão
# presentes — se faltar alguma, o processo morre com mensagem clara.

# ---- HTTP server ----
PORT=4000
NODE_ENV=production
LOG_LEVEL=info   # trace | debug | info | warn | error

# ---- MySQL (mesmo banco da apiv2: adawong em dbca.hunterbr.com) ----
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=

# ---- PostgreSQL (ht_advert — réplica passiva de Plus) ----
PG_HOST=
PG_PORT=
PG_USER=
PG_PASSWORD=
PG_DATABASE=

# ---- Apple App Store Server API (StoreKit 2 / JWS) ----
# In-App Purchase Key criada em App Store Connect → Users and Access →
# Integrations → In-App Purchase. .p8 fica em .secrets/.
APPLE_ISSUER_ID=
APPLE_KEY_ID=
APPLE_KEY_PATH=.secrets/apple_subscription_key.p8
APPLE_BUNDLE_ID=radio.hunterfm
APPLE_APP_ID=
APPLE_ENV=production   # production | sandbox (fallback automático no verifier)

# ---- Google Play Developer API ----
# Service account JSON fica em .secrets/. packageName é fixo da Hunter.FM.
GOOGLE_APPLICATION_CREDENTIALS=.secrets/google_play_service_account.json
GOOGLE_PACKAGE_NAME=com.hunterfm

# ---- Stripe ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=price_1SzOUuRuFEI1fHJkMzsI6VOn
STRIPE_PRICE_SEMESTRAL=price_1SzOWRRuFEI1fHJkggnjqmBA
STRIPE_PRICE_ANNUAL=price_1SzOVdRuFEI1fHJkZrkPRHwE

# ---- Discord (alertas e logs operacionais) ----
DISCORD_TOKEN=
DISCORD_PURCHASE_CHANNEL_ID=1342885161339191488   # canal de alertas de purchases

# ---- Comunicações (push e email do hunterbr) ----
PUSH_URL=https://push.hunterbr.com/user-notification
PUSH_AUTH=
EMAIL_URL=https://nl.hunterbr.com/hunterplus
EMAIL_AUTH=

# ---- Admin (rotas /admin/*) ----
ADMIN_TOKEN=

# ---- Modo teste PIX (NUNCA usar em produção) ----
# Quando true, encurta a expiração de compras PIX (Android one-time):
#   mensal     → 3 minutos
#   semestral  → 5 minutos
#   anual      → 10 minutos
# Permite testar o ciclo de expiração de PIX sem esperar 1/6/12 meses.
# Default: false. Em produção: NÃO definir ou setar pra "false".
PIX_TEST_MODE=false
